{
  "name": "Jamu Loader — Test Manifest",
  "version": "1.0.0",
  "description": "Manifest untuk testing Jamu Loader extension",
  "author": "yourname",
  "modules": [
    {
      "id": "test-banner",
      "name": "Test Banner",
      "version": "1.0.2",
      "icon": "🧪",
      "defaultEnabled": false,
      "description": "Banner test — muncul di pojok kanan bawah selama 5 detik",
      "scriptUrl": "https://raw.githubusercontent.com/cobrabagaskara/centralized-userscript-manager/main/modules/test-banner.js",
      "matches": [
        "https://*/*",
        "http://*/*"
      ]
    },
    {
      "id": "highlight-links",
      "name": "Highlight Links",
      "version": "1.0.1",
      "icon": "🔗",
      "defaultEnabled": false,
      "description": "Highlight semua link di halaman dengan outline teal",
      "scriptUrl": "https://raw.githubusercontent.com/cobrabagaskara/centralized-userscript-manager/main/modules/highlight-links.js",
      "matches": [
        "https://*.detik.com/*"
      ]
    },
    {
      "id": "google-notifikasi",
      "name": "Google Notifikasi Draggable",
      "version": "1.2",
      "icon": "🧩",
      "description": "Menampilkan UI draggable di Google dengan notifikasi",
      "defaultEnabled": true,
      "scriptUrl": "https://raw.githubusercontent.com/cobrabagaskara/centralized-userscript-manager/main/modules/google-notifikasi.js",
      "matches": [
        "https://www.google.com/*",
        "https://google.com/*",
        "https://*.epuskesmas.id/*"
      ]
    },

    {
  "id": "bpjs-survey-auto-fill",
  "name": "BPJS Survey Auto Fill",
  "version": "1.5",
  "icon": "📝",
  "description": "Auto fill BPJS survey - semua jawaban 'Tidak', auto next page",
  "defaultEnabled": false,
  "scriptUrl": "https://raw.githubusercontent.com/cobrabagaskara/centralized-userscript-manager/main/modules/bpjs-survey-auto-fill.js",
  "matches": [
    "https://webskrining.bpjs-kesehatan.go.id/*"
  ]
}



    
  ]
}
